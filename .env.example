# ── Ascend Environment Variables ─────────────────────────────────────
# Copy this file to .env for local development.
# For production, set these in Render dashboard (never commit secrets).

# Required: JWT signing secret (generate a 64-char random string)
ASCEND_JWT_SECRET=change-me-to-a-random-64-char-string

# Required: Base URL of the deployed app (no trailing slash)
ASCEND_BASE_URL=http://127.0.0.1:8000

# OAuth: Google (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth: Spotify (get from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
